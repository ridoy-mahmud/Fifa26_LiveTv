/**
 * Server-side stream proxy — GET /api/proxy?url=<encoded>
 *
 * Fetches streams server-side (bypasses CORS), spoofs Referer/Origin so
 * IPTV servers accept the request, and rewrites .m3u8 manifests so all
 * segment URLs also go through this proxy.
 */
import { createFileRoute } from "@tanstack/react-router";
import type {} from "@tanstack/react-start";

const CORS: Record<string, string> = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Methods": "GET, HEAD, OPTIONS",
  "Access-Control-Allow-Headers": "*",
  "Access-Control-Expose-Headers": "*",
};

function isM3u8(url: string, ct: string): boolean {
  const u = url.toLowerCase().split("?")[0];
  return u.endsWith(".m3u8") || u.endsWith(".m3u") || ct.includes("mpegurl");
}

function rewriteM3u8(text: string, baseUrl: string, origin: string): string {
  const base = new URL(baseUrl);
  const proxy = `${origin}/api/proxy`;
  const wrap = (raw: string) => {
    try { return `${proxy}?url=${encodeURIComponent(new URL(raw, base).href)}`; }
    catch { return raw; }
  };
  return text.split("\n").map((line) => {
    const t = line.trim();
    if (t.startsWith("#") && t.includes('URI="')) {
      return line.replace(/URI="([^"]+)"/g, (_m, u) => `URI="${wrap(u)}"`);
    }
    if (!t || t.startsWith("#")) return line;
    return wrap(t);
  }).join("\n");
}

function makeHeaders(target: URL): Record<string, string> {
  return {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
    Accept: "*/*",
    "Accept-Language": "en-US,en;q=0.9",
    "Accept-Encoding": "identity",
    Referer: `${target.origin}/`,
    Origin: target.origin,
    "Cache-Control": "no-cache",
    "icy-metadata": "1",
  };
}

export const Route = createFileRoute("/api/proxy")({
  server: {
    handlers: {
      OPTIONS: async () => new Response(null, { status: 204, headers: CORS }),
      GET: async ({ request }) => {
        const reqUrl = new URL(request.url);
        const target = reqUrl.searchParams.get("url");
        if (!target) return new Response("Missing url", { status: 400, headers: CORS });

        let tUrl: URL;
        try { tUrl = new URL(target); }
        catch { return new Response("Invalid url", { status: 400, headers: CORS }); }

        if (tUrl.protocol !== "http:" && tUrl.protocol !== "https:") {
          return new Response("Protocol not allowed", { status: 403, headers: CORS });
        }

        try {
          const res = await fetch(target, { headers: makeHeaders(tUrl), redirect: "follow" });
          if (!res.ok) {
            return new Response(`Upstream ${res.status}`, { status: res.status, headers: CORS });
          }

          const rawCt = res.headers.get("content-type") ?? "";
          const ct = rawCt.toLowerCase();

          if (isM3u8(target, ct)) {
            const text = await res.text();
            return new Response(rewriteM3u8(text, target, reqUrl.origin), {
              status: 200,
              headers: { ...CORS, "Content-Type": "application/vnd.apple.mpegurl", "Cache-Control": "no-cache" },
            });
          }

          const h: Record<string, string> = {
            ...CORS,
            "Cache-Control": "no-cache",
            "Content-Type": (ct && !ct.includes("html") && !ct.includes("json")) ? rawCt : "video/mp2t",
          };
          const cl = res.headers.get("content-length");
          if (cl) h["Content-Length"] = cl;
          return new Response(res.body, { status: 200, headers: h });
        } catch (err) {
          return new Response(`Proxy error: ${err instanceof Error ? err.message : String(err)}`, { status: 502, headers: CORS });
        }
      },
    },
  },
});
