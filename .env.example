# ─── MongoDB Atlas (server-side only) ──────────────────────────────────────
# Copy this file to `.env` and fill in real values. On Vercel, set these in
# Project Settings → Environment Variables (Production + Preview).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=wc2026

# ─── Admin credentials (server-side only, never sent to the client) ────────
# Used to seed the very first admin user. After login you can rotate the
# password from the admin panel.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-deploying
