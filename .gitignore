# ── Stream / channel data that must NOT be committed ───────────────────────
# Raw source JSON dumps used to seed channels (contain live stream URLs).
# The compiled TypeScript source (channels-data.ts) is intentionally kept
# so the app builds, but the raw JSON inputs are excluded.
json/
*.m3u
playlists/
streams/
exported-channels*.json
stream-links*.json
live-links*.json

